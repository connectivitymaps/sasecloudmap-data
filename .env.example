AUTH=
DEV_HOSTNAME="https://dev.example.com/add"
PROD_HOSTNAME="https://example.com/add"
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
PROXY_ENDPOINT_API_TOKEN=
# Store the proxy endpoint hostname only, without https://.
PROXY_ENDPOINT="example.proxy.cloudflare-gateway.com"
BROWSER_RENDERING_API_TOKEN=
BROWSER_RENDERING_JSON_MODEL="workers-ai/@cf/moonshotai/kimi-k2.5"
# Optional local-only corporate proxy CA support.
# If your Python/OpenSSL stack still rejects intercepted HTTPS with the extra CA,
# also set RELAX_X509_STRICT=1.
EXTRA_CA_CERT_FILE=
RELAX_X509_STRICT=
CACHE_PURGE_KEY=
R2_ACCOUNT_ID="example-account-id"
R2_ACCESS_KEY_ID="example-access-key-id"
R2_SECRET_ACCESS_KEY="example-secret-access-key"
R2_BUCKET_NAME="example-snapshots-bucket"
