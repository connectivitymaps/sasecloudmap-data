+const LOCATION_CLUSTER_RADIUS_KM = 50
+
+function getPointCoordinates(feature) {
+  const coordinates = feature?.geometry?.type === 'Point' ? feature.geometry.coordinates : null
+  if (!Array.isArray(coordinates) || coordinates.length < 2) {
+    return null
+  }
+  const [longitude, latitude] = coordinates
+  return Number.isFinite(longitude) && Number.isFinite(latitude) ? [longitude, latitude] : null
+}
+
+function distanceKm([longitudeA, latitudeA], [longitudeB, latitudeB]) {
+  const toRadians = (degrees) => (degrees * Math.PI) / 180
+  const deltaLatitude = toRadians(latitudeB - latitudeA)
+  const deltaLongitude = toRadians(longitudeB - longitudeA)
+  const a =
+    Math.sin(deltaLatitude / 2) ** 2 +
+    Math.cos(toRadians(latitudeA)) * Math.cos(toRadians(latitudeB)) * Math.sin(deltaLongitude / 2) ** 2
+  return 6371.0088 * 2 * Math.asin(Math.sqrt(a))
+}
+
+function countriesCanCluster(a, b) {
+  return !a.countryCode || !b.countryCode || a.countryCode === b.countryCode
+}
+
+function rowsCanCluster(a, b) {
+  if (a.coordinates && b.coordinates) {
+    return countriesCanCluster(a, b) && distanceKm(a.coordinates, b.coordinates) <= LOCATION_CLUSTER_RADIUS_KM
+  }
+  return !a.coordinates && !b.coordinates && a.city === b.city && countriesCanCluster(a, b)
+}
+
+function isCodeLikeLabel(label) {
+  return /^[A-Z0-9]{3,}$/.test(label) || /\d$/.test(label)
+}
